# Copy this file to .env and fill in your local values.
# .env is gitignored — never commit real credentials.
#
# These values feed BOTH the Python app and the Postgres container
# (docker-compose.yml interpolates DB_NAME / DB_USER / DB_PASSWORD / DB_PORT).

# ---- Database (app role: read/write) -------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=fraud_intel
DB_USER=postgres
DB_PASSWORD=change_me

# ---- Database (least-privilege role used by the NL2SQL agent) ------------
# Created by db/setup_readonly_role.sql, which reads DB_READONLY_PASSWORD.
# This role cannot write, and cannot see transactions.is_fraud.
DB_READONLY_USER=fraud_intel_readonly
DB_READONLY_PASSWORD=change_me_too

# ---- Local LLM (Ollama) --------------------------------------------------
OLLAMA_HOST=http://localhost:11434
AGENT_MODEL=llama3.2:3b
