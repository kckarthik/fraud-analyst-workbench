# ---- Secrets -------------------------------------------------------------
# .env holds real local credentials. .env.example is the committed template.
.env
.env.local
.env.*.local

# ---- Python --------------------------------------------------------------
venv/
.venv/
env/
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/

# ---- Node / frontend -----------------------------------------------------
node_modules/
frontend/dist/
frontend/.vite/
npm-debug.log*
yarn-error.log*

# ---- Data ----------------------------------------------------------------
# Raw source datasets (PaySim / IEEE-CIS) are large and redistributable only
# from their original sources. See README for download instructions.
data/
*.csv
!tests/fixtures/*.csv

# ---- Model artifacts -----------------------------------------------------
# Binary model files are build outputs, reproducible via model/train.py.
# The JSON metrics + feature columns ARE committed: they're small, diffable,
# and serve as the record of what a given commit actually scored.
model/artifacts/*.joblib
model/artifacts/*.pkl
model/artifacts/*.bin

# ---- Editors / OS --------------------------------------------------------
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db
